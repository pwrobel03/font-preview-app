// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          Role      @default(VIEWER)
  createdAt     DateTime  @default(now()) @map("created_at")
  fontsAdded    Font[]

  // NextAuth
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Font {
  id          String       @id @default(cuid())
  name        String                          // Display name, e.g. "Playfair Display"
  slug        String       @unique            // URL-safe, e.g. "playfair-display"
  source      FontSource   @default(GOOGLE)
  familyCss   String       @map("family_css") // Value for font-family CSS
  googleName  String?      @map("google_name") // Exact name in Google Fonts API
  filePath    String?      @map("file_path")   // /public/fonts/xxx.woff2 for local fonts
  category    FontCategory @default(SANS_SERIF)
  subsets     String[]     @default(["latin"]) // e.g. ["latin","latin-ext","cyrillic"]
  tags        String[]     @default([])        // e.g. ["elegant","editorial","headings"]
  isActive    Boolean      @default(true) @map("is_active")
  addedBy     String?      @map("added_by")
  addedByUser User?        @relation(fields: [addedBy], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("fonts")
}

enum Role {
  ADMIN
  VIEWER
}

enum FontSource {
  GOOGLE
  LOCAL
}

enum FontCategory {
  SERIF
  SANS_SERIF
  MONOSPACE
  DISPLAY
  HANDWRITING
}
